@model Web.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard de Equipamentos TI";
}

<div class="container-fluid">
    <h1 class="mt-4">Dashboard de Equipamentos TI</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">Visão Geral de todos os equipamentos</li>
    </ol>

    <div class="row">
        <div class="col-xl-2 col-md-4">
            <div class="card bg-primary text-white mb-4 text-center">
                <div class="card-body">
                    <h5 class="card-title">Computadores</h5>
                    <h2>@Model.TotalComputadores</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4">
            <div class="card bg-success text-white mb-4 text-center">
                <div class="card-body">
                    <h5 class="card-title">Monitores</h5>
                    <h2>@Model.TotalMonitores</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4">
            <div class="card bg-info text-white mb-4 text-center">
                <div class="card-body">
                    <h5 class="card-title">Periféricos</h5>
                    <h2>@Model.TotalPerifericos</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4">
            <div class="card bg-warning text-white mb-4 text-center">
                <div class="card-body">
                    <h5 class="card-title">Redes</h5>
                    <h2>@Model.TotalRedes</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4">
            <div class="card bg-danger text-white mb-4 text-center">
                <div class="card-body">
                    <h5 class="card-title">Smartphones</h5>
                    <h2>@Model.TotalSmartphones</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4">
            <div class="card bg-secondary text-white mb-4 text-center">
                <div class="card-body">
                    <h5 class="card-title">Total</h5>
                    <h2>@(Model.TotalComputadores + Model.TotalMonitores + Model.TotalPerifericos + Model.TotalRedes + Model.TotalSmartphones)</h2>
                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-lg-6">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-chart-pie me-1"></i>
                    Status das Garantias
                </div>
                <div class="card-body"><canvas id="garantiaPieChart" width="100%" height="50"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-chart-bar me-1"></i>
                    Vencimento das Garantias (Linha do Tempo)
                </div>
                <div class="card-body"><canvas id="garantiaBarChart" width="100%" height="50"></canvas></div>
            </div>
        </div>
    </div>

    <div class="card mb-4">

        <div class="card-header">
            <i class="fas fa-table me-1"></i>
            Lista Geral de Equipamentos
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-bordered" id="datatablesSimple">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>ID / MAC / PN</th>
                            <th>Modelo / Nome</th>
                            <th>Responsável</th>
                            <th>Garantia</th>
                            <th>Backup</th>
                            <th>Data da Coleta (Comp.)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Equipamentos)
                        {
                            <tr>
                                <td>@item.TipoEquipamento</td>
                                <td>@item.Identificador</td>
                                <td>@item.ModeloOuNome</td>
                                <td>@item.ColaboradorNome</td>
                                <td>
                                    @if(item.DataGarantia.HasValue) {
                                        @if(item.DataGarantia.Value < DateTime.Now) {
                                            <span class="text-danger fw-bold">@item.DataGarantia.Value.ToString("dd/MM/yyyy") (Vencida)</span>
                                        } else {
                                            <span class="text-success">@item.DataGarantia.Value.ToString("dd/MM/yyyy")</span>
                                        }
                                    } else {
                                        <span class="text-muted">S/ Informação</span>
                                    }
                                </td>
                                <td>@item.Backup</td>
                                <td>@(item.DataColeta.HasValue ? item.DataColeta.Value.ToString("dd/MM/yyyy HH:mm:ss") : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            if ($.fn.DataTable) {
                $('#datatablesSimple').DataTable({
                    "language": {
                        "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json"
                    }
                });
            }

            // Pie Chart
            var ctxPie = document.getElementById("garantiaPieChart");
            if (ctxPie) {
                var pieData = @Html.Raw(Json.Serialize(Model.GarantiaPieData));
                new Chart(ctxPie, {
                    type: 'pie',
                    data: {
                        labels: ["Tem garantia", "Sem garantia", "Sem dados de garantia"],
                        datasets: [{
                            data: pieData,
                            backgroundColor: ['#28a745', '#dc3545', '#6c757d'],
                        }],
                    },
                });
            }

            // Bar Chart
            var ctxBar = document.getElementById("garantiaBarChart");
            if (ctxBar) {
                var barData = @Html.Raw(Json.Serialize(Model.GarantiaBarData));
                var labels = barData.map(function(d) { return d.label; });
                var data = barData.map(function(d) { return d.value; });
                new Chart(ctxBar, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: "Equipamentos a vencer",
                            backgroundColor: "rgba(2,117,216,1)",
                            borderColor: "rgba(2,117,216,1)",
                            data: data,
                        }],
                    },
                    options: {
                        scales: {
                            x: {
                                grid: {
                                    display: false
                                }
                            },
                            y: {
                                ticks: {
                                    min: 0,
                                    maxTicksLimit: 5
                                },
                                grid: {
                                    display: true
                                }
                            }
                        },
                        plugins: {
                            legend: {
                                display: false
                            }
                        }
                    }
                });
            }
        });
    </script>
}