@model Web.Models.ManutencaoIndexViewModel

@{
    ViewData["Title"] = "Manutenções";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (User.IsInRole("Admin"))
{
    <div class="row mb-3">
        <div class="col-md-12">
            <form asp-controller="Manutencoes" asp-action="Importar" method="post" enctype="multipart/form-data">
                <div class="input-group">
                    <input type="file" name="file" class="form-control" />
                    <button type="submit" class="btn btn-success">Importar</button>
                    <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#helpModal">Ajuda de Importação</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal de Ajuda -->
    <div class="modal fade" id="helpModal" tabindex="-1" aria-labelledby="helpModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="helpModalLabel">Estrutura do Excel para Manutenções</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p>O arquivo Excel (.xlsx) deve conter as seguintes colunas na ordem abaixo, começando na primeira linha (cabeçalho não importa, mas a ordem sim):</p>
            <ol>
                <li><strong>ComputadorMAC</strong></li>
                <li><strong>MonitorPartNumber</strong></li>
                <li><strong>PerifericoPartNumber</strong></li>
                <li><strong>DataManutencaoHardware</strong> (Formato: DD/MM/AAAA)</li>
                <li><strong>DataManutencaoSoftware</strong> (Formato: DD/MM/AAAA)</li>
                <li><strong>ManutencaoExterna</strong></li>
                <li><strong>Data</strong> (Formato: DD/MM/AAAA)</li>
                <li><strong>Historico</strong></li>
            </ol>
            <p><strong>Atenção:</strong> Pelo menos um dispositivo (ComputadorMAC, MonitorPartNumber ou PerifericoPartNumber) deve ser preenchido.</p>
            <p><strong>Atenção:</strong> A leitura começa a partir da <strong>linha 2</strong>.</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
          </div>
        </div>
      </div>
    </div>

    <p>
        <a asp-action="Create" class="btn btn-primary">Adicionar Nova Manutenção</a>
    </p>
}

<div class="card mb-4">
    <div class="card-header" id="filterHeader">
        <h5 class="mb-0">
            <button class="btn btn-link text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false" aria-controls="filterCollapse">
                Filtros
            </button>
        </h5>
    </div>
    <div id="filterCollapse" class="collapse" aria-labelledby="filterHeader">
        <form asp-action="Index" method="get" class="card-body" id="manutencoes-filter-form">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="partNumber" class="form-label">PartNumber (Computador, Monitor ou Periférico)</label>
                    <input type="text" id="partNumber" name="partNumber" class="form-control" value="@Model.PartNumber">
                </div>
                <div class="col-md-4">
                    <label for="colaborador" class="form-label">Nome do Colaborador</label>
                    <input type="text" id="colaborador" name="colaborador" class="form-control" value="@Model.Colaborador">
                </div>
                <div class="col-md-4">
                    <label for="hostname" class="form-label">Hostname</label>
                    <input type="text" id="hostname" name="hostname" class="form-control" value="@Model.Hostname">
                </div>
            </div>
            <div class="mt-3 text-end">
                <a asp-action="Index" class="btn btn-secondary">Limpar Filtros</a>
                <button type="submit" class="btn btn-primary">Aplicar Filtros</button>
            </div>
        </form>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                Equipamento
            </th>
            <th>
                Data Manutenção Hardware
            </th>
            <th>
                Data Manutenção Software
            </th>
            <th>
                Manutenção Externa
            </th>
            <th>
                Data
            </th>
            <th>
                Histórico
            </th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Manutencoes)
        {
            <tr>
                <td>
                    @if (item.Computador != null)
                    {
                        <span>@item.Computador.Hostname (@item.Computador.MAC)</span>
                    }
                    else if (item.Monitor != null)
                    {
                        <span>@item.Monitor.Modelo (@item.Monitor.PartNumber)</span>
                    }
                    else if (item.Periferico != null)
                    {
                        <span>@item.Periferico.Tipo (@item.Periferico.PartNumber)</span>
                    }
                </td>
                <td class="@GetDateClass(item.DataManutencaoHardware)">
                    @Html.DisplayFor(modelItem => item.DataManutencaoHardware)
                </td>
                <td class="@GetDateClass(item.DataManutencaoSoftware)">
                    @Html.DisplayFor(modelItem => item.DataManutencaoSoftware)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ManutencaoExterna)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Data)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Historico)
                </td>
                <td>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@functions {
    public string GetDateClass(DateTime? date)
    {
        if (!date.HasValue)
        {
            return "";
        }

        var today = DateTime.Today;
        var months = (today.Year - date.Value.Year) * 12 + today.Month - date.Value.Month;
        if (today.Day < date.Value.Day)
        {
            months--;
        }

        if (months >= 12)
        {
            return "table-danger"; // red
        }
        else if (months >= 6)
        {
            return "table-warning"; // yellow
        }
        else
        {
            return ""; // normal
        }
    }
}

@section Scripts {
    <script src="~/js/manutencao-filter-persistence.js" asp-append-version="true"></script>
}
