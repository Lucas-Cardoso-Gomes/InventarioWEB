@model IEnumerable<Web.Models.Periferico>

@{
    ViewData["Title"] = "Periféricos";
}

<h1>Periféricos</h1>

@if (User.IsInRole("Admin"))
{
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <a asp-action="Create" class="btn btn-primary">Adicionar Novo Periférico</a>
        <form asp-controller="Perifericos" asp-action="Importar" method="post" enctype="multipart/form-data" class="d-flex m-0">
            <div class="input-group">
                <input type="file" name="file" class="form-control" />
                <button type="submit" class="btn btn-success">Importar</button>
                <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#helpModal">Ajuda de Importação</button>
            </div>
        </form>
    </div>

    <!-- Modal de Ajuda -->
    <div class="modal fade" id="helpModal" tabindex="-1" aria-labelledby="helpModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="helpModalLabel">Estrutura do Excel para Periféricos</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p>O arquivo Excel (.xlsx) deve conter as seguintes colunas na ordem abaixo, começando na primeira linha (cabeçalho não importa, mas a ordem sim):</p>
            <ol>
                <li><strong>PartNumber</strong> (Obrigatório)</li>
                <li><strong>ColaboradorCPF</strong> (Apenas números)</li>
                <li><strong>Tipo</strong></li>
                <li><strong>DataEntrega</strong> (Formato: DD/MM/AAAA)</li>
            </ol>
            <p><strong>Atenção:</strong> A leitura começa a partir da <strong>linha 2</strong>.</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
          </div>
        </div>
      </div>
    </div>
}

<div class="row mb-3">
    <div class="col-md-12">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="searchString" class="form-control" placeholder="Procurar..." value="@ViewData["CurrentFilter"]">
                <button class="btn btn-outline-secondary" type="submit">Procurar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered table-hover align-middle">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Tipo)</th>
                <th>@Html.DisplayNameFor(model => model.ColaboradorNome)</th>
                <th>@Html.DisplayNameFor(model => model.DataEntrega)</th>
                <th>@Html.DisplayNameFor(model => model.PartNumber)</th>
                <th>@Html.DisplayNameFor(model => model.DataGarantia)</th>
                @if (User.IsInRole("Admin"))
                {
                    <th>
                        Ações
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Tipo)</td>
                    <td>@Html.DisplayFor(modelItem => item.ColaboradorNome)</td>
                    <td>@Html.DisplayFor(modelItem => item.DataEntrega)</td>
                    <td>@Html.DisplayFor(modelItem => item.PartNumber)</td>
                    <td>@(item.DataGarantia.HasValue ? item.DataGarantia.Value.ToString("dd/MM/yyyy") : "")</td>
                    @if (User.IsInRole("Admin"))
                    {
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.PartNumber" class="btn btn-warning btn-sm">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.PartNumber" class="btn btn-danger btn-sm">Excluir</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
